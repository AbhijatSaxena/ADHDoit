rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      // Allow users to create their own doc with viewer role on sign-up
      allow create: if isAuth() && request.auth.uid == uid && request.resource.data.role == 'viewer';
      allow update, delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /focusState/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }
  }
}
